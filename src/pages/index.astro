---
// @ts-nocheck
import SiteNav from "../components/SiteNav.astro";
import Prism from "../components/Prism";
import Lanyard from "../components/Lanyard";
---

<Prism
    client:only="react"
    animationType="rotate"
    glow={1.2}
    noise={0.25}
    bloom={1.1}
/>
<SiteNav active="home" />

<main>
    <Lanyard client:only="react" position={[0, 0, 20]} gravity={[0, -40, 0]} />
</main>

<style>
    @import url("https://fonts.cdnfonts.com/css/open-sauce-one");

    :global(html),
    :global(body) {
        color-scheme: dark;
        margin: 0;
        padding: 0;
        width: 100%;
        min-height: 100%;
        overflow: hidden;
        background: radial-gradient(
            circle at 20% 20%,
            #1b2028 0%,
            #0b0d10 45%,
            #050608 100%
        );
        color: #f2f5f7;
        font-family: "Open Sauce One", sans-serif;
    }

    main {
        position: relative;
        width: 100%;
        min-height: 100vh;
    }
</style>
