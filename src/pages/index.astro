---
// @ts-nocheck
import SiteNav from "../components/SiteNav.astro";
import Prism from "../components/Prism";
import Lanyard from "../components/Lanyard";
import TextType from "../components/TextType";
import ScrollReveal from "../components/ScrollReveal";
import HeroSocials from "../components/HeroSocials";
import ScrollVelocity from "../components/ScrollVelocity";
---

<Prism
    client:only="react"
    animationType="rotate"
    glow={1.2}
    noise={0.25}
    bloom={1.1}
/>
<SiteNav active="home" />

<main>
    <section class="home-hero">
        <section class="home-title">
            <TextType
                client:only="react"
                as="h1"
                text={["Welcome to \n Ritesh's Portfolio"]}
                typingSpeed={65}
                pauseDuration={1500}
                deletingSpeed={45}
                loop={false}
                showCursor
                cursorCharacter="_"
                cursorBlinkDuration={0.5}
                className="home-title-text"
            />
            <p class="hero-tagline">CS & Economics @ Allegheny College</p>
            <HeroSocials client:only="react" />
            <div class="hero-cta-row">
                <a class="hero-cta hero-cta--primary" href="/projects"
                    >View my work</a
                >
                <a
                    class="hero-cta hero-cta--secondary"
                    href="/resume.pdf"
                    target="_blank"
                    rel="noreferrer noopener"
                >
                    Resume
                </a>
            </div>
        </section>
        <Lanyard
            client:only="react"
            position={[0, 0, 20]}
            gravity={[0, -40, 0]}
        />
    </section>

    <section class="mini-stats-section" aria-label="Highlights">
        <div class="mini-stats-grid">
            <article class="mini-stat-card">
                <p class="mini-stat-value">4+</p>
                <p class="mini-stat-label">Projects Built</p>
            </article>
            <article class="mini-stat-card">
                <p class="mini-stat-value">2+</p>
                <p class="mini-stat-label">Hackathons</p>
                <p class="mini-stat-note">Finalist and Mini Hackathon winner</p>
            </article>
            <article class="mini-stat-card">
                <p class="mini-stat-value">7+</p>
                <p class="mini-stat-label">Campus Clubs</p>
            </article>
        </div>
    </section>

    <section class="about-section" id="about">
        <p class="about-label">About Me</p>
        <div class="about-description-bg">
            <ScrollReveal
                client:only="react"
                text="Rising junior at Allegheny College studying CS and Economics. I build tools at the intersection of software and real-world systems, currently working on BizMap, a compliance platform for first-time small business owners."
                baseOpacity={0.75}
                enableBlur={false}
                baseRotation={1.5}
                blurStrength={1}
                containerClassName="about-reveal"
                textClassName="about-reveal-text"
            />
        </div>
    </section>

    <section class="tech-strip-section" aria-label="Core tools">
        <ScrollVelocity
            client:only="react"
            texts={[
                "HTML | CSS | JavaScript | Git | Astro | Next.js | TypeScript | Python | PostgreSQL | Supabase | React",
            ]}
            velocity={65}
            className="custom-scroll-text"
            numCopies={8}
            damping={45}
            stiffness={360}
            velocityMapping={{ input: [0, 1000], output: [0, 2.2] }}
            parallaxClassName="tech-parallax"
            scrollerClassName="tech-scroller"
        />
    </section>
</main>

<style>
    @import url("https://fonts.cdnfonts.com/css/open-sauce-one");
    :global(html),
    :global(body) {
        color-scheme: dark;
        margin: 0;
        padding: 0;
        width: 100%;
        min-height: 100%;
        overflow-x: hidden;
        overflow-y: auto;
        background: radial-gradient(
            circle at 20% 20%,
            #1b2028 0%,
            #0b0d10 45%,
            #050608 100%
        );
        color: #f2f5f7;
        font-family: "Open Sauce One", sans-serif;
    }

    main {
        position: relative;
        width: 100%;
        min-height: 200vh;
    }

    .home-hero {
        position: relative;
        min-height: 100vh;
    }

    .home-title {
        position: absolute;
        inset: 0;
        z-index: 5;
        display: grid;
        place-items: center;
        pointer-events: none;
        text-align: center;
        align-content: center;
        gap: 0.7rem;
        padding: 0 1rem;
    }

    :global(.home-title-text) {
        font-size: clamp(1.8rem, 4.8vw, 4rem);
        line-height: 1.05;
        letter-spacing: -0.03em;
        color: #f8fbff;
        text-shadow: 0 10px 40px rgba(0, 0, 0, 0.35);
    }

    .hero-tagline {
        margin: 0;
        color: rgba(242, 245, 247, 0.78);
        font-size: clamp(0.9rem, 1.35vw, 1.15rem);
        letter-spacing: 0.04em;
        text-transform: uppercase;
        pointer-events: none;
    }

    :global(.hero-socials) {
        display: inline-flex;
        align-items: center;
        gap: 0.6rem;
        pointer-events: auto;
    }

    :global(.hero-socials a) {
        width: 2.15rem;
        height: 2.15rem;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: rgba(242, 245, 247, 0.62);
        background: rgba(8, 12, 16, 0.48);
        border: 1px solid rgba(255, 255, 255, 0.11);
        text-decoration: none;
        transition:
            color 150ms ease,
            background-color 150ms ease,
            border-color 150ms ease,
            transform 150ms ease;
    }

    :global(.hero-socials a:hover),
    :global(.hero-socials a:focus-visible) {
        color: rgba(242, 245, 247, 0.9);
        background: rgba(8, 12, 16, 0.72);
        border-color: rgba(255, 255, 255, 0.22);
        transform: translateY(-1px);
        outline: none;
    }

    .hero-cta-row {
        display: inline-flex;
        align-items: center;
        gap: 0.7rem;
        pointer-events: auto;
        margin-top: 0.1rem;
    }

    .hero-cta {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 8.7rem;
        padding: 0.62rem 1rem;
        border-radius: 999px;
        font-size: 0.86rem;
        letter-spacing: 0.03em;
        text-decoration: none;
        transition:
            transform 160ms ease,
            background-color 160ms ease,
            color 160ms ease,
            border-color 160ms ease;
    }

    .hero-cta:hover,
    .hero-cta:focus-visible {
        transform: translateY(-1px);
        outline: none;
    }

    .hero-cta--primary {
        background: rgba(248, 251, 255, 0.95);
        color: #0b0d10;
        border: 1px solid rgba(255, 255, 255, 0.55);
    }

    .hero-cta--primary:hover,
    .hero-cta--primary:focus-visible {
        background: #ffffff;
    }

    .hero-cta--secondary {
        background: rgba(8, 12, 16, 0.58);
        color: rgba(242, 245, 247, 0.88);
        border: 1px solid rgba(255, 255, 255, 0.25);
    }

    .hero-cta--secondary:hover,
    .hero-cta--secondary:focus-visible {
        background: rgba(8, 12, 16, 0.76);
        color: rgba(242, 245, 247, 0.98);
    }

    .mini-stats-section {
        position: relative;
        z-index: 6;
        max-width: 980px;
        margin: 0 auto;
        padding: 1rem 1.5rem 1.5rem;
    }

    .mini-stats-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 0.8rem;
    }

    .mini-stat-card {
        padding: 0.9rem 1rem;
        border-radius: 16px;
        background: rgba(6, 9, 14, 0.58);
        border: 1px solid rgba(255, 255, 255, 0.14);
        backdrop-filter: blur(5px);
    }

    .mini-stat-value {
        margin: 0;
        font-size: clamp(1.2rem, 2.2vw, 1.65rem);
        font-weight: 700;
        color: rgba(248, 251, 255, 0.98);
    }

    .mini-stat-label {
        margin: 0.2rem 0 0;
        color: rgba(242, 245, 247, 0.82);
        font-size: 0.84rem;
        letter-spacing: 0.04em;
        text-transform: uppercase;
    }

    .mini-stat-note {
        margin: 0.35rem 0 0;
        color: rgba(242, 245, 247, 0.7);
        font-size: 0.8rem;
        line-height: 1.35;
    }

    .about-section {
        position: relative;
        z-index: 6;
        max-width: 980px;
        margin: 0 auto;
        padding: 6rem 1.5rem 6rem;
    }

    .about-description-bg {
        padding: clamp(1.15rem, 2.2vw, 2rem);
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 24px;
        background: rgba(0, 0, 0, 0.9);
        box-shadow: 0 18px 50px rgba(0, 0, 0, 0.55);
        backdrop-filter: blur(6px);
    }

    .about-label {
        margin: 0 0 1rem;
        text-transform: uppercase;
        letter-spacing: 0.16em;
        font-size: 0.95rem;
        font-weight: 700;
        color: rgba(242, 245, 247, 0.92);
    }

    :global(.about-reveal) {
        margin: 0;
    }

    :global(.about-reveal-text) {
        margin: 0;
        color: rgba(248, 251, 255, 0.98);
        font-size: clamp(0.95rem, 1.4vw, 1.15rem);  !important;
        line-height: 1.38;
        font-weight: 600;
        letter-spacing: -0.01em;
        text-shadow: 0 10px 38px rgba(0, 0, 0, 0.35);
    }

    .tech-strip-section {
        position: relative;
        z-index: 6;
        max-width: 980px;
        margin: 0 auto;
        padding: 0.2rem 1.5rem 2.25rem;
    }

    :global(.tech-parallax) {
        border-radius: 16px;
        border: 1px solid rgba(255, 255, 255, 0.14);
        background: rgba(8, 12, 16, 0.52);
        backdrop-filter: blur(5px);
        padding: 0.36rem 0;
    }

    :global(.tech-scroller) {
        font-family: "Open Sauce One", sans-serif;
        font-size: clamp(0.82rem, 1.55vw, 1.05rem);
        line-height: 1.25;
        font-weight: 600;
        letter-spacing: 0.01em;
        filter: none;
    }

    :global(.custom-scroll-text) {
        color: rgba(242, 245, 247, 0.78);
        padding-inline: 0.75rem;
    }

    @media (min-width: 768px) {
        :global(.tech-scroller) {
            font-size: clamp(0.92rem, 1.12vw, 1.2rem);
            line-height: 1.4;
        }
    }

    @media (max-width: 700px) {
        .mini-stats-grid {
            grid-template-columns: 1fr;
        }

        .tech-strip-section {
            padding-bottom: 1.75rem;
        }

        .hero-cta-row {
            flex-wrap: wrap;
            justify-content: center;
        }

        .hero-cta {
            min-width: 7.9rem;
            padding: 0.58rem 0.9rem;
        }

        .about-section {
            padding-top: 5rem;
        }
    }
</style>
