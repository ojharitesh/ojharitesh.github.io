---
const { active = "home" } = Astro.props;

const navItems = [
    { label: "Home", href: "/", id: "home" },
    { label: "Projects", href: "/projects", id: "projects" },
    { label: "Experience", href: "/experience", id: "experience" },
    { label: "Skills", href: "/skills", id: "skills" },
    {
        label: "Outside the IDE",
        shortLabel: "Beyond",
        href: "/outside-the-ide",
        id: "outside-the-ide",
    },
];
---

<nav class="site-nav" aria-label="Primary">
    {
        navItems.map((item) => (
            <a
                href={item.href}
                aria-current={active === item.id ? "page" : undefined}
                class:list={{ active: active === item.id }}
            >
                <span class="nav-full">{item.label}</span>
                {item.shortLabel && (
                    <span class="nav-short">{item.shortLabel}</span>
                )}
            </a>
        ))
    }
</nav>

<style>
    .site-nav {
        position: fixed;
        top: 1.5rem;
        left: 50%;
        z-index: 20;
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.7rem 0.85rem;
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-radius: 999px;
        background: rgba(8, 10, 14, 0.72);
        box-shadow: 0 18px 50px rgba(0, 0, 0, 0.35);
        backdrop-filter: blur(14px);
        -webkit-backdrop-filter: blur(14px);
        transform: translateX(-50%) translateZ(0);
        max-width: calc(100vw - 1.5rem);
        overflow-x: auto;
        scrollbar-width: none;
        will-change: transform;
        -webkit-backface-visibility: hidden;
        backface-visibility: hidden;
    }

    .site-nav::-webkit-scrollbar {
        display: none;
    }

    .site-nav a {
        padding: 0.55rem 0.9rem;
        border-radius: 999px;
        color: #f2f5f7;
        text-decoration: none;
        font-size: 0.95rem;
        letter-spacing: 0.02em;
        white-space: nowrap;
        transition:
            background-color 140ms ease,
            color 140ms ease,
            transform 140ms ease;
    }

    .site-nav a:hover,
    .site-nav a:focus-visible,
    .site-nav a.active {
        background: rgba(255, 255, 255, 0.1);
        color: #ffffff;
        transform: translateY(-1px);
        outline: none;
    }

    /* Short labels hidden by default */
    .nav-short {
        display: none;
    }

    /* ── Tablet / small desktop ── */
    @media (max-width: 700px) {
        .site-nav {
            top: 1rem;
            gap: 0.15rem;
            padding: 0.5rem 0.55rem;
        }

        .site-nav a {
            padding: 0.42rem 0.6rem;
            font-size: 0.8rem;
        }
    }

    /* ── Small phones ── */
    @media (max-width: 480px) {
        .site-nav {
            top: 0.75rem;
            gap: 0.1rem;
            padding: 0.42rem 0.45rem;
        }

        .site-nav a {
            padding: 0.38rem 0.5rem;
            font-size: 0.72rem;
            letter-spacing: 0;
        }

        /* Switch to short label for links that have one */
        .nav-short {
            display: inline;
        }
        a:has(.nav-short) .nav-full {
            display: none;
        }
    }

    /* ── Very small phones (< 380px) ── */
    @media (max-width: 380px) {
        .site-nav a {
            padding: 0.35rem 0.4rem;
            font-size: 0.68rem;
        }
    }
</style>

