---
import SiteNav from "./SiteNav.astro";

const { active, title, subtitle } = Astro.props;
---

<SiteNav active={active} />

<main class="section-shell">
    <section class="hero-card">
        {subtitle ? <p class="eyebrow">{subtitle}</p> : null}
        <h1>{title}</h1>
        <div class="content">
            <slot />
        </div>
    </section>
</main>

<style>
    @import url("https://fonts.cdnfonts.com/css/open-sauce-one");

    :global(html),
    :global(body) {
        font-family: "Open Sauce One", sans-serif;
    }

    .section-shell {
        min-height: 100vh;
        display: grid;
        place-items: center;
        padding: 7rem 1.5rem 2rem;
    }

    .hero-card {
        width: min(980px, 100%);
        padding: clamp(1.5rem, 4vw, 3rem);
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-radius: 32px;
        background:
            radial-gradient(
                circle at top left,
                rgba(255, 255, 255, 0.08),
                transparent 38%
            ),
            rgba(8, 10, 14, 0.72);
        box-shadow: 0 30px 80px rgba(0, 0, 0, 0.35);
        backdrop-filter: blur(18px);
    }

    .eyebrow {
        margin: 0 0 0.75rem;
        color: rgba(242, 245, 247, 0.72);
        text-transform: uppercase;
        letter-spacing: 0.18em;
        font-size: 0.78rem;
    }

    h1 {
        margin: 0;
        font-size: clamp(2.5rem, 5vw, 4.6rem);
        line-height: 0.95;
        letter-spacing: -0.04em;
    }

    .content {
        margin-top: 1.4rem;
        display: grid;
        gap: 1rem;
        color: rgba(242, 245, 247, 0.84);
        font-size: 1.02rem;
        line-height: 1.7;
    }

    @media (max-width: 700px) {
        .section-shell {
            padding-top: 6.5rem;
        }

        .hero-card {
            border-radius: 24px;
        }
    }
</style>
